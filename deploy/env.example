DJANGO_SECRET_KEY=replace-me
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=ntnu.1024.no
# DJANGO_CSRF_TRUSTED_ORIGINS=https://ntnu.1024.no
# DJANGO_SECURE_PROXY_SSL_HEADER=HTTP_X_FORWARDED_PROTOCOL,https
# DJANGO_USE_X_FORWARDED_HOST=true

TIMETABLE_INSTITUTION=NTNU
EMAIL_SUBJECT_PREFIX=[TIMEPLAN-NTNU]
STATIC_URL=//ntnu.1024.no/_/static/
COMPRESS_URL=//ntnu.1024.no/_/cache/

PGDATABASE=plan
PGUSER=plan
PGPASSWORD=replace-me
PGHOST=127.0.0.1
PGPORT=5432
PGCONN_MAX_AGE=300

# Optional: use memcached for default cache backend
# MEMCACHED_LOCATION=127.0.0.1:11211
# MEMCACHED_KEY_PREFIX=ntnu

# Optional override (image default: /var/lib/plan)
# PLAN_BASE_DIR=/var/lib/plan
# PLAN_CACHE_DIR=/var/cache/plan

# Static/compressor roots (container defaults shown)
# PLAN_STATIC_ROOT=/static
# PLAN_COMPRESS_ROOT=/var/cache/plan/static

# Optional Sentry
# SENTRY_DSN=https://example@sentry.io/1
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.001

# Runtime listener mode: socket (default), http, both
# This deploy flow uses socket and overrides image default HTTP mode.
PLAN_UWSGI_LISTENER=socket
PLAN_UWSGI_SOCKET=/run/uwsgi/uwsgi.sock
# PLAN_UWSGI_HTTP=0.0.0.0:8080

# Optional overrides (image defaults: 4 / 1)
# PLAN_UWSGI_PROCESSES=4
# PLAN_UWSGI_THREADS=1

# Optional: override uWSGI access log format, or disable with 'off'
# PLAN_UWSGI_LOG_FORMAT=off
